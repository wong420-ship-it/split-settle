flowchart TD
    Start(["Open SeatSolo"]) --> Choice{"Host or Guest?"}

    Choice -->|Host| H1["Sign in"]
    H1 --> H2["Create bill session<br/>(share_code generated)"]
    H2 --> H3["Scan / upload receipt"]
