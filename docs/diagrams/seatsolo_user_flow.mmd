    Live --> C1["Claim items<br/>(toggle, multi-claimer split)"]
    C1 --> C2["View 'Me' summary<br/>subtotal + tax + tip share"]
    C2 --> C3["Mark as paid"]

    Live --> HD["Host dashboard<br/>running totals, leftovers"]
    HD --> HE["Edit / delete items"]
    HD --> HS["Share link / native share"]
